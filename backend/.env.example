# Port to run the server on
PORT=5050

# Environment (development, production, test)
NODE_ENV=development

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/fleetdash

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# CORS Origin limit (can be a comma-separated list or * in development)
CORS_ORIGIN=*

# Worker Pool sizing (optional, defaults to CPU count - 1)
WORKER_POOL_SIZE=4

# Limit of tasks queued before rejecting telemetry requests (HTTP 503)
QUEUE_LIMIT=10000
